---
import SiteLayout from '../layouts/SiteLayout.astro';

const albums = [
	{ title: 'Candy Shop', year: 1955, cover: '/album-covers/Dean-Tool-candy-shop.jpg' },
	{ title: 'Knuckle', year: 1962, cover: '/album-covers/Dean-tool-knuckle.jpg' },
	{ title: 'Give It Away', year: 1968, cover: '/album-covers/Dean-Tool-give-it-away.jpg' },
	{ title: 'Many Gumbas', year: 1971, cover: '/album-covers/Dean-tool-many-gumbas.jpeg' },
	{ title: 'Natural Born Killa', year: 1975, cover: '/album-covers/Dean-Tool-natural-born-killa.jpg' },
	{ title: 'Puttana Closer', year: 1980, cover: '/album-covers/Puttana-closer-dean-tool.jpg' },
	{ title: 'Sings the Standards', year: 1985, cover: '/album-covers/Dean-Tool-sings-the-standards.jpg' },
	{ title: 'Dames', year: 1990, cover: '/album-covers/dean-tool-dames.jpg' },
	{ title: 'Wack That A', year: 1995, cover: '/album-covers/Dean-tool-Wack-That-A.jpg' },
	{ title: 'Wack That B', year: 1996, cover: '/album-covers/Dean-tool-Wack-That-B.jpg' },
	{ title: 'Spaghetti Pot', year: 2000, cover: '/album-covers/dean-tool-spaghetti-pot.jpg' },
	{ title: 'I Wanna Fuck You', year: 2005, cover: '/album-covers/i-wanna-fuck-you-dean-tool.jpg' },
	{ title: 'I Wanna Wack You', year: 2010, cover: '/album-covers/i-wanna-wack-you-dean-tool.jpg' },
	{ title: 'Angel of Death', year: 2015, cover: '/album-covers/Dean-tool-angel-of-death_.jpg' },
	{ title: 'Horny', year: 2020, cover: '/album-covers/Dean-tool-horny.jpg' }
];
---

<SiteLayout
	title="Dean Tool Discography"
	description="The records, covers, and catalog of Dean Tool."
	active="discography"
>
	<section class="section">
		<div class="section-panel">
			<div class="section-heading">
				<div>
					<span class="eyebrow">Discography</span>
					<h1 class="section-title">A catalog with teeth.</h1>
				</div>
				<p class="section-copy">
					From lounge classics to darker late-career records, the catalog moves through romance,
					sinister wit, and polished chaos.
				</p>
			</div>
			<div class="album-grid">
				{
					albums.map((album) => (
						<article class="album-card">
							<div class="album-cover">
								<img src={album.cover} alt={album.title} loading="lazy" />
							</div>
							<div class="album-body">
								<div class="album-year">{album.year}</div>
								<h2 class="card-title">{album.title}</h2>
								<p class="album-meta">Studio release</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>
</SiteLayout>
