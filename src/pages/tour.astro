---
import SiteLayout from '../layouts/SiteLayout.astro';

const shows = [
	{ date: 'May 15, 2026', venue: 'The Blue Note', city: 'New York, NY', note: 'An intimate opening-night set.' },
	{ date: 'June 3, 2026', venue: 'Jazz Alley', city: 'Seattle, WA', note: 'Late show with expanded brass section.' },
	{ date: 'July 12, 2026', venue: 'Village Vanguard', city: 'New York, NY', note: 'Midnight arrangements and deep cuts.' },
	{ date: 'August 20, 2026', venue: "Yoshi's Oakland", city: 'Oakland, CA', note: 'West coast stop with stripped-back set design.' },
	{ date: 'September 5, 2026', venue: 'The Dakota', city: 'Minneapolis, MN', note: 'Closing weekend with a long encore.' }
];
---

<SiteLayout
	title="Dean Tool Tour Dates"
	description="Upcoming live dates for Dean Tool."
	active="tour"
>
	<section class="section">
		<div class="section-panel">
			<div class="section-heading">
				<div>
					<span class="eyebrow">Live Dates</span>
					<h1 class="section-title">The midnight circuit.</h1>
				</div>
				<p class="section-copy">
					A run of rooms selected for atmosphere first. Expect warm light, sharp tailoring, and a set
					that gets heavier as the night goes on.
				</p>
			</div>
			<div class="show-grid">
				{
					shows.map((show) => (
						<article class="show-card">
							<div class="show-date">{show.date}</div>
							<h2 class="card-title">{show.venue}</h2>
							<p class="card-copy">{show.city}</p>
							<p class="muted">{show.note}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>
</SiteLayout>
