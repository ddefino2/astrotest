---
import SiteLayout from '../layouts/SiteLayout.astro';

const stats = [
	{ value: '14', label: 'Signature recordings in the catalog' },
	{ value: '3', label: 'Cities anchoring the summer run' },
	{ value: '1', label: 'Voice made for the showroom spotlight' }
];

const shows = [
	{ date: 'May 15, 2026', venue: 'The Blue Note', city: 'New York, NY' },
	{ date: 'June 3, 2026', venue: 'Jazz Alley', city: 'Seattle, WA' },
	{ date: 'July 12, 2026', venue: 'Village Vanguard', city: 'New York, NY' }
];

const quotes = [
	{
		quote: '“A showroom headliner with the nerve to sing every line like it belongs in gold leaf.”',
		source: 'Sound Weekly'
	},
	{
		quote: '“Velvet arrangements, steel confidence, and not a wasted spotlight anywhere in the room.”',
		source: 'The Midnight Trade Journal'
	},
	{
		quote: '“An artist who treats excess like a discipline.”',
		source: 'Velvet Static Magazine'
	}
];
---

<SiteLayout
	title="Dean Tool | Crooner Extraordinaire"
	description="A modern artist website for Dean Tool with tour dates, records, and midnight-soul atmosphere."
	active="home"
>
	<section class="hero">
		<div class="hero-panel">
			<span class="eyebrow">Showroom Season 2026</span>
			<h1 class="hero-title">Dean Tool</h1>
			<p class="hero-subtitle">
				Dean Tool brings cathedral-scale drama to the velvet room: towering arrangements, midnight
				luxury, and a voice built for the kind of stage that glows long after the house lights fall.
			</p>
			<div class="hero-actions">
				<a class="button" href="/tour">See The Tour</a>
				<a class="button-secondary" href="/discography">Explore The Records</a>
			</div>
		</div>
		<div class="hero-stack">
			<div class="feature-card feature-art">
				<div>
					<span class="feature-kicker">Featured Release</span>
					<strong>Angel of Death</strong>
					<p>A slow-burn showroom anthem wrapped in brass, smoke, and immaculate tailoring.</p>
				</div>
			</div>
			<div class="feature-card portrait-panel">
				<img src="/dean-tool-stage.png" alt="Dean Tool in a tuxedo under dramatic stage light." />
				<div class="portrait-caption">
					<span class="feature-kicker">Publicity Shot</span>
					<strong>The headline voice of a long golden hour.</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-panel">
			<div class="section-heading">
				<div>
					<span class="eyebrow">At A Glance</span>
					<h2 class="section-title">Made for rooms that expect more from the night.</h2>
				</div>
				<p class="section-copy">
					The Dean Tool sound moves between classic lounge, dark brass soul, and grand theatrical
					spectacle, always delivered with absolute control.
				</p>
			</div>
			<div class="stats-grid">
				{
					stats.map((stat) => (
						<div class="stat-card">
							<strong>{stat.value}</strong>
							<span>{stat.label}</span>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-panel">
			<div class="section-heading">
				<div>
					<span class="eyebrow">Upcoming Dates</span>
					<h2 class="section-title">Reserve the evening before the marquee fills the block.</h2>
				</div>
				<a class="button-secondary" href="/tour">Full Schedule</a>
			</div>
			<div class="show-grid">
				{
					shows.map((show) => (
						<article class="show-card">
							<div class="show-date">{show.date}</div>
							<h3 class="card-title">{show.venue}</h3>
							<p class="card-copy">{show.city}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-panel">
			<div class="section-heading">
				<div>
					<span class="eyebrow">Press</span>
					<h2 class="section-title">A reputation polished to showroom shine.</h2>
				</div>
				<p class="section-copy">
					For Dean Tool, scale is part of the craft: the voice, the staging, the silhouette, and the
					feeling that every entrance should arrive under its own constellation of lights.
				</p>
			</div>
			<div class="press-grid">
				{
					quotes.map((item) => (
						<article class="press-card">
							<blockquote>{item.quote}</blockquote>
							<p>{item.source}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<p class="footer-note">Official artist site. Midnight luxury, brass light, and the long glow of the marquee.</p>
</SiteLayout>
