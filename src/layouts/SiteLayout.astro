---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	active?: 'home' | 'tour' | 'discography' | 'about';
}

const { title, description = 'The official home of Dean Tool.', active } = Astro.props;

const navItems = [
	{ href: '/', label: 'Home', key: 'home' },
	{ href: '/tour', label: 'Tour', key: 'tour' },
	{ href: '/discography', label: 'Discography', key: 'discography' },
	{ href: '/about', label: 'About', key: 'about' }
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<div class="ambient ambient-one"></div>
			<div class="ambient ambient-two"></div>
			<header class="site-header">
				<a class="brand" href="/">
					<span class="brand-mark">DT</span>
					<span class="brand-copy">
						<strong>Dean Tool</strong>
						<small>Midnight soul. Velvet static.</small>
					</span>
				</a>
				<nav class="site-nav" aria-label="Primary">
					{
						navItems.map((item) => (
							<a href={item.href} class:list={{ active: active === item.key }}>
								{item.label}
							</a>
						))
					}
				</nav>
			</header>
			<main class="site-main">
				<slot />
			</main>
		</div>
	</body>
</html>
